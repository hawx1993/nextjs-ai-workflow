{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/dangerous-command-guard.mjs"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/dependency-guard.mjs"
          }
        ],
        "description": "阻断危险命令和未经确认的新增依赖"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/tsx-quality-guard.mjs"
          }
        ],
        "description": "提醒 TS/TSX 硬编码文案、硬编码颜色、console.log 和 LANG 可疑用法"
      }
    ]
  }
}
